<launch>
  <let name="slam_params"
       value="$(find-pkg-share my_robot_bringup)/config/slam_params.yaml" />
  <let name="urdf_path"
       value="$(find-pkg-share urdf_description)/urdf/urdf.xacro" />

  <node pkg="slam_toolbox"
        exec="async_slam_toolbox_node"
        name="slam_toolbox"
        output="screen">
    <param from="$(var slam_params)" />
    <param name="use_sim_time" value="true" />
  </node>

  <node pkg="joint_state_publisher"
        exec="joint_state_publisher"
        name="joint_state_publisher">
    <param name="use_sim_time" value="true" />
    <param name="robot_description"
           value="$(command 'xacro $(var urdf_path)')" />
  </node>

  <node pkg="rviz2" exec="rviz2" name="rviz2" output="screen" />
</launch>