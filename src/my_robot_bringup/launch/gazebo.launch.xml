<launch>
    <let name="urdf_path"
         value="$(find-pkg-share urdf_description)/urdf/urdf.xacro" />

    <let name="rviz_config_path"
         value="$(find-pkg-share my_robot_bringup)/rviz/urdf_config.rviz" />

    <node pkg="robot_state_publisher" exec="robot_state_publisher">
        <param name="robot_description"
              value="$(command 'xacro $(var urdf_path)')" />
    </node>

    <include file="$(find-pkg-share gazebo_ros)/launch/gazebo.launch.py">
        <arg name="world" value="/home/kaushik/major_ws/src/my_robot_bringup/worlds/orchard.world" />
    </include>
    
    <node pkg="gazebo_ros" exec="spawn_entity.py"
      args="-topic robot_description -entity my_robot -x -3 -y 0 -z 0.3" />

    <node pkg="ros_gz_bridge" exec="parameter_bridge">
          <param name = "config_file" value="$(find-pkg-share my_robot_bringup)/config/gazebo_bridge.yaml"/>
    </node>

</launch>